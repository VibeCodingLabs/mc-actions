# moonclaw-actions-factory — .env.example
# Validated via Context7. Copy to .env — never commit .env.

# CONTEXT7 — https://context7.com
CONTEXT7_API_KEY=

# TAVILY — https://tavily.com
TAVILY_API_KEY=

# JINA — https://jina.ai
JINA_API_KEY=

# FIRECRAWL — https://firecrawl.dev
FIRECRAWL_API_KEY=
FIRECRAWL_WEBHOOK_SECRET=

# HUGGING FACE — https://huggingface.co/settings/tokens
HF_TOKEN=
HF_HOME=~/.cache/huggingface
HF_ENDPOINT=https://api-inference.huggingface.co
HF_JOBS_API_KEY=
HF_SPACES_TOKEN=
HF_DYNAMIC_SPACES=true

# N8N — https://docs.n8n.io
N8N_API_KEY=
N8N_WEBHOOK_URL=http://localhost:5678

# GITHUB — https://github.com/settings/tokens
# GitHub App: https://github.com/settings/apps/new
GITHUB_TOKEN=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GH_ORG=VibeCodingLabs
GH_REPO=moonclaw-actions-factory

# GEMINI 2.5 FLASH — https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# PERPLEXITY — https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar-pro

# OPENROUTER — https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash:free

# GROQ — https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# CEREBRAS — https://cloud.cerebras.ai
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama3.1-70b

# SAMBANOVA — https://cloud.sambanova.ai
SAMBANOVA_API_KEY=
SAMBANOVA_MODEL=DeepSeek-R1-0528

# NVIDIA NIM — https://build.nvidia.com
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# MISTRAL — https://console.mistral.ai
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# RUNPOD — https://www.runpod.io
RUNPOD_API_KEY=
RUNPOD_ENDPOINT=

# VAST.AI — https://vast.ai
VAST_API_KEY=

# REDIS / BULLMQ
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# SQLITE
SQLITE_PATH=/var/lib/moonclaw/jobs.db

# SENTRY — https://sentry.io/signup/
SENTRY_DSN=

# POSTHOG — https://posthog.com/pricing
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# STRIPE — https://dashboard.stripe.com/register
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# PAYPAL — https://developer.paypal.com
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# GUMROAD — https://gumroad.com
GUMROAD_ACCESS_TOKEN=
GUMROAD_WEBHOOK_SECRET=

# LEMON SQUEEZY — https://www.lemonsqueezy.com
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=

# PAYHIP — https://payhip.com
PAYHIP_API_KEY=

# UPWORK — https://www.upwork.com/developer/keys
UPWORK_CLIENT_ID=
UPWORK_CLIENT_SECRET=

# FIVERR — https://www.fiverr.com
FIVERR_API_KEY=

# FREELANCER — https://developers.freelancer.com
FREELANCER_CLIENT_ID=
FREELANCER_CLIENT_SECRET=

# NEON POSTGRES — https://neon.tech
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# SOCIAL MEDIA
# Twitter/X: https://developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Reddit: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# Discord: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
DISCORD_WEBHOOK_URL=

# Telegram: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# Slack: https://api.slack.com/apps
SLACK_BOT_TOKEN=
SLACK_WEBHOOK_URL=

# YouTube: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# SESSION
SESSION_SECRET=change-me-min-32-chars
COOKIE_DOMAIN=.yourdomain.com
COOKIE_SECURE=true

# APP
NODE_ENV=production
PORT=8000
BASE_URL=https://yourdomain.com
LOG_LEVEL=info
OBSIDIAN_VAULT_PATH=~/obsidian-vault
